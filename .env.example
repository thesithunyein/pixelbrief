# Required for live x402 payments on X Layer
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
PAY_TO_ADDRESS=0xYourAgenticWalletAddress

# eip155:196 = X Layer mainnet | eip155:1952 = X Layer testnet
X402_NETWORK=eip155:196

# Set false to run free endpoints for local / Vercel preview without OKX keys
REQUIRE_PAYMENT=false

PORT=4000
PUBLIC_BASE_URL=https://pixelbrief.tech

# Optional AI logo generation — ChatGPT / OpenAI
# https://platform.openai.com/api-keys
# Note: dall-e-2 / dall-e-3 were retired May 12, 2026. Use gpt-image-*.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=medium
AI_IMAGE_PROVIDER=openai

# Optional Gemini (often free-tier image quota = 0)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
