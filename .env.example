# Required for live x402 payments on X Layer
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
PAY_TO_ADDRESS=0xYourAgenticWalletAddress

# eip155:196 = X Layer mainnet | eip155:1952 = X Layer testnet
X402_NETWORK=eip155:196

# Set false to run free endpoints for local / Vercel preview without OKX keys
REQUIRE_PAYMENT=false

PORT=4000
PUBLIC_BASE_URL=https://pixelbrief.vercel.app

# Optional AI logo generation (Gemini preferred, OpenAI fallback)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
OPENAI_IMAGE_MODEL=gpt-image-1
