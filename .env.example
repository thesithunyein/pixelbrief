# Required for live x402 payments on X Layer
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
PAY_TO_ADDRESS=0xYourAgenticWalletAddress

# eip155:196 = X Layer mainnet | eip155:1952 = X Layer testnet
X402_NETWORK=eip155:196

# Set false to run free endpoints for local demo without OKX keys
REQUIRE_PAYMENT=true

PORT=4000
PUBLIC_BASE_URL=https://your-pixelbrief.example.com
